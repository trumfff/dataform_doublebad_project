config {
  type: "view",
  schema: "stg_haravan",
  name: "stg_haravan_orders",
  description: "Parse Haravan orders: flatten header + customer{}, √©p ki·ªÉu (ID‚ÜíSTRING, ti·ªÅn‚ÜíFLOAT64, ISO‚ÜíTIMESTAMP). GI·ªÆ m·ªçi snapshot. line_items ƒë·ªÉ raw cho order_items.",
  tags: ["staging", "haravan"]
}

SELECT
  CAST(shop_id AS STRING)        AS shop_id,
  ingest_dt,
  CAST(id AS STRING)             AS order_id,
  order_number,
  name,
  financial_status,
  fulfillment_status,
  closed_status,
  cancelled_status,
  confirmed_status,
  gateway                        AS payment_method,
  source,
  source_name,
  currency,
  email,
  note,
  cancel_reason,
  CAST(location_id AS STRING)    AS location_id,
  location_name,
  CAST(user_id AS STRING)        AS user_id,
  CAST(customer.id AS STRING)    AS customer_id,
  customer.first_name            AS customer_first_name,
  customer.phone                 AS customer_phone,
  CAST(customer.total_spent AS FLOAT64) AS customer_total_spent,
  customer.orders_count          AS customer_orders_count,
  CAST(subtotal_price AS FLOAT64)          AS subtotal_price,
  CAST(total_line_items_price AS FLOAT64)  AS total_line_items_price,
  CAST(total_discounts AS FLOAT64)         AS total_discounts,
  CAST(total_price AS FLOAT64)             AS total_price,
  CAST(total_tax AS FLOAT64)               AS total_tax,
  CAST(total_weight AS FLOAT64)            AS total_weight,
  CAST(created_at AS TIMESTAMP)   AS create_time,
  CAST(updated_at AS TIMESTAMP)   AS update_time,
  CAST(confirmed_at AS TIMESTAMP) AS confirmed_at,
  CAST(cancelled_at AS TIMESTAMP) AS cancelled_at,
  line_items,
  _ingested_at
FROM ${ref("haravan_orders")}
